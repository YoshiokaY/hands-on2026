# 内部API (/api/weather) の認証に使うシークレットトークン
#
# クライアントから送られる X-API-Secret-Token ヘッダーの値と、この環境変数を
# サーバー側 (Route Handler) で照合します。一致した場合のみ気象庁APIへ
# プロキシし、不一致・未設定の場合は 401 Unauthorized を返します。
#
# クライアント側のトークンは src/app/page.tsx に固定値で埋め込んでいます。
# ローカルで認証を通すには、その値と同じ文字列をここに設定してください。
#   cp .env.example .env.local
#
# Vercel: 管理画面 (Settings > Environment Variables) で設定します。
# 環境変数は Production / Preview / Development で別々に管理されるため、
# Production だけでなく Preview にも設定すること（未設定だとプレビューで 401 になる）。
API_SECRET_TOKEN=HANDSON_SECRET_TOKEN_2026

# --- 任意: Vercel バックエンドストレージ体験 ---
# 未設定でもアプリは動作します（該当機能を自動でスキップ）。

# Upstash Redis（地方アクセスランキングの集計）
# Vercel Marketplace で Upstash for Redis を追加すると、KV_* の変数が自動注入されます。
# コードは UPSTASH_REDIS_REST_* を優先し、無ければ KV_REST_API_* を読みます（どちらでも可）。
# ローカルで試す場合は Upstash 管理画面の .env.local タブから下記をコピーしてください。
KV_REST_API_URL=
KV_REST_API_TOKEN=
# （別名で設定する場合はこちらでも可）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Vercel Edge Config（お知らせバナー）
# Edge Config ストアを作成・連携すると自動注入されます。
# ストアに `announcement` キー（文字列、または {"message": "...", "enabled": true}）を登録すると、
# 再デプロイなしでバナーが即時反映されます。
EDGE_CONFIG=
